title: "Decision Debt DAWO26 Reproducibility Package: capacity matrix and robustness analysis"
version: "1.0.0"
doi: "10.5281/zenodo.20406810"
date-released: "2026-05-27"
type: software
authors:
  - family-names: "Paroushev"
    given-names: "Deyan"
